# Base URL of your admin app (where the API lives). No trailing slash.
# If the admin app is under a path (e.g. /self-study), include it:
#   NEXT_PUBLIC_API_URL=http://localhost:3000/self-study
# Development: admin on 3000, this app on 3001.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Production (PM2/self-hosted): set a fixed base64 key so Server Action IDs stay valid
# across restarts and avoid "Failed to find Server Action" errors. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your-base64-key-here
